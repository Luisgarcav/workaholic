{
  "name": "workaholic",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "bun --preload @opentui/solid/preload --hot src/index.tsx",
    "start": "bun --preload @opentui/solid/preload src/index.tsx",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build": "bun run scripts/build.ts",
    "build:linux": "bun run scripts/build.ts linux-x64",
    "build:macos": "bun run scripts/build.ts macos"
  },
  "dependencies": {
    "@opentui/core": "0.4.5",
    "@opentui/solid": "0.4.5",
    "solid-js": "1.9.12"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "typescript": "5.9.3"
  }
}
